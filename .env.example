# Copy to .env and adjust. NEVER commit the real .env.

ENVIRONMENT=development
LOG_LEVEL=INFO
APP_NAME="FinanceOps Automation Platform"

# Local default is SQLite; uncomment Postgres for production.
# DATABASE_URL=sqlite:///./data/financeops.db
DATABASE_URL=postgresql+psycopg2://financeops:financeops@db:5432/financeops
DB_ECHO=false

# Anomaly detection thresholds
ANOMALY_ZSCORE_THRESHOLD=2.5
ANOMALY_PCT_DROP_THRESHOLD=0.20
ANOMALY_ROLLING_WINDOW=7
